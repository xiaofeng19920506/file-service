{
  "name": "file-service",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend/api",
    "backend/worker",
    "shared"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:web",
    "build:shared": "npm run build -w @file-service/shared",
    "build:api": "npm run build -w @file-service/api",
    "build:worker": "npm run build -w @file-service/worker",
    "build:web": "npm run build -w @file-service/web",
    "build:backend": "npm run build -w @file-service/shared && npm run build -w @file-service/api && npm run build -w @file-service/worker",
    "build:prod": "npm run build:backend && npm run build:web",
    "dev": "concurrently -k -n api,worker,web -c blue,green,magenta \"tsx watch backend/api/src/index.ts\" \"tsx watch backend/worker/src/index.ts\" \"npm run dev:web\"",
    "dev:api-web": "concurrently -k -n api,web -c blue,magenta \"tsx watch backend/api/src/index.ts\" \"npm run dev:web\"",
    "dev:docker": "bash scripts/dev-mode.sh docker",
    "dev:docker:libre": "bash scripts/dev-mode.sh libre",
    "dev:stop": "bash scripts/dev-mode.sh stop",
    "dev:status": "bash scripts/dev-mode.sh status",
    "dev:api": "tsx watch backend/api/src/index.ts",
    "dev:api-only": "docker compose -f shared/docker-compose.yml up -d postgres redis && npm run dev:api",
    "dev:api-audio": "docker compose -f shared/docker-compose.yml up -d postgres redis && concurrently -k -n api,worker -c blue,green \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:api-audio-5w": "bash scripts/start-api-workers.sh 5",
    "dev:worker": "tsx watch backend/worker/src/index.ts",
    "dev:worker:merge": "tsx watch backend/worker/src/worker-merge.ts",
    "dev:worker:audio": "tsx watch backend/worker/src/worker-audio.ts",
    "dev:web": "npm run dev -w @file-service/web",
    "start": "node backend/api/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "npm run db:generate -w @file-service/shared",
    "db:migrate": "npm run db:migrate -w @file-service/shared",
    "db:migrate:run": "npm run db:migrate:run -w @file-service/shared",
    "sync:bulletin-template": "bash scripts/sync-bulletin-template.sh",
    "tunnel:start": "bash scripts/cloudflared-tunnel.sh start",
    "tunnel:status": "bash scripts/cloudflared-tunnel.sh status",
    "tunnel:stop": "bash scripts/cloudflared-tunnel.sh stop",
    "tunnel:setup-server": "bash scripts/setup-cloudflared-server.sh",
    "tunnel:login": "bash scripts/cloudflared-named-tunnel.sh login",
    "tunnel:setup": "bash scripts/cloudflared-named-tunnel.sh setup",
    "tunnel:run": "bash scripts/cloudflared-named-tunnel.sh run",
    "tunnel:status:named": "bash scripts/cloudflared-named-tunnel.sh status",
    "tunnel:stop:named": "bash scripts/cloudflared-named-tunnel.sh stop",
    "tunnel:sync-env": "bash scripts/sync-tunnel-env.sh",
    "tunnel:install-launchagent": "bash scripts/autostart/install-macos.sh install-all",
    "tunnel:install-launchagent:tunnel": "bash scripts/autostart/install-macos.sh install-tunnel",
    "tunnel:install-launchagent:api": "bash scripts/autostart/install-macos.sh install-api",
    "tunnel:uninstall-launchagent": "bash scripts/autostart/uninstall-macos.sh",
    "tunnel:launchagent-status": "bash scripts/autostart/install-macos.sh status",
    "tunnel:autostart": "bash scripts/autostart/tunnel.sh",
    "api:autostart": "bash scripts/autostart/api-stack.sh",
    "seed:app-store-review": "tsx scripts/seed-app-store-review.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
