{
  "name": "file-service",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @file-service/shared && npm run build -w @file-service/api && npm run build -w @file-service/worker && npm run build -w @file-service/web",
    "build:prod": "npm run build -w @file-service/shared && npm run build -w @file-service/web && npm run build -w @file-service/api",
    "dev": "concurrently -k -n api,worker,web -c blue,green,magenta \"tsx watch apps/api/src/index.ts\" \"tsx watch apps/worker/src/index.ts\" \"npm run dev:web\"",
    "dev:docker": "bash scripts/dev-mode.sh docker",
    "dev:docker:full": "bash scripts/dev-mode.sh full",
    "dev:local": "bash scripts/dev-mode.sh docker",
    "dev:stop": "bash scripts/dev-mode.sh stop",
    "dev:status": "bash scripts/dev-mode.sh status",
    "dev:api": "tsx watch apps/api/src/index.ts",
    "dev:worker": "tsx watch apps/worker/src/index.ts",
    "dev:web": "npm run dev -w @file-service/web",
    "start": "node apps/api/dist/index.js",
    "prod:docker": "bash scripts/prod.sh",
    "prod:docker:down": "docker compose -f docker-compose.prod.yml down",
    "prod:docker:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "npm run db:generate -w @file-service/shared",
    "db:migrate": "npm run db:migrate -w @file-service/shared",
    "db:migrate:run": "npm run db:migrate:run -w @file-service/shared"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2",
    "fastify": "^5.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
