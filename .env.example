DATABASE_URL=postgresql://fileservice:fileservice@localhost:5432/fileservice
STORAGE_BACKEND=fs
LOCAL_STORAGE_DIR=./data/storage

# API only
PORT=3000
# 前端地址（CORS + 分享邮件链接，逗号分隔多个）
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# WEB_APP_URL=http://localhost:5173
MAX_UPLOAD_MB=200
# 可选：设置后所有 /v1/* 请求需携带 Authorization: Bearer <key> 或 X-API-Key
# API_KEY=your-secret-api-key-min-8-chars
# 用户认证（默认开启，所有 /v1/* 需登录；设为 false 可本地开放）
# AUTH_REQUIRED=true
# USER_SESSION_TTL_SECONDS=1892160000
# 注册用户默认为 member；管理员在后台 /admin 调整角色
# （以下两项已不再用于注册自动赋权，可忽略）
# ADMIN_EMAILS=
# WORSHIP_TEAM_EMAILS=
DOWNLOAD_HMAC_SECRET=replace-with-at-least-16-chars
DOWNLOAD_URL_TTL_SECONDS=3600
PUBLIC_BASE_URL=http://localhost:3000

# 可选：API 托管前端静态资源（一般不需要，前后端已分离）
# STATIC_DIR=./frontend/dist

# 开发：Vite 代理目标（默认 http://localhost:3000）
# VITE_DEV_API_PROXY=http://localhost:3000

# Worker only（本机开发）
SOFFICE_PATH=soffice
# 周报 PPT 预览：Docker LibreOffice 服务（npm run dev:docker 会自动启动）
SOFFICE_PREVIEW_URL=http://localhost:3010
# MP3 缓存：需安装 yt-dlp + ffmpeg（brew install yt-dlp ffmpeg）并运行 worker
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
# YouTube 403/限流：使用本机浏览器登录态（chrome / safari / firefox）
# YT_DLP_COOKIES_FROM_BROWSER=safari
# 可选：固定 player_client，失败时会自动尝试 android/tv_embedded 等
# YT_DLP_PLAYER_CLIENT=android,web
# 多 worker 时请求间隔（秒），减轻 403
# YT_DLP_SLEEP_REQUESTS=0.75
# 每个 MP3 worker 进程内并发（多进程时建议每个设为 1）
# YOUTUBE_AUDIO_WORKER_CONCURRENCY=1
# 并行处理的合并任务数（默认 1；LibreOffice 占用内存大，勿设过高）
WORKER_CONCURRENCY=1
# 多 worker 启动：npm run dev:api-audio-5w  →  API + 5×MP3 worker + 5×视频 worker + 1×合并 worker

# 可选：设置 RUN_MIGRATIONS=0 可禁用 API 启动时自动迁移
# RUN_MIGRATIONS=1
# 生产环境默认关闭 Swagger；开发自动开启，或设 ENABLE_OPENAPI=1 强制开启
# ENABLE_OPENAPI=1
# 全局限流（Redis 计数，按 API Key 或 IP）
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# 上传接口更严格限流（同一窗口内 POST 上传次数）
RATE_LIMIT_UPLOAD_MAX=30

# 可选：Webhook 签名密钥（Worker POST 时设置 X-Webhook-Signature HMAC-SHA256）
# WEBHOOK_SECRET=your-webhook-signing-secret

# 可选：YouTube Data API v3 密钥（未配置时也会尝试自动读取链接；配置后更稳定）
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# YOUTUBE_API_KEY=your-youtube-data-api-key

# 可选：导出到 YouTube 播放列表（OAuth，仅 worship_team / admin 可用）
# Google Cloud Console → 凭据 → OAuth 2.0 客户端 ID（Web 应用）
# 已授权重定向 URI 需包含：{PUBLIC_BASE_URL}/v1/youtube/oauth/callback
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/v1/youtube/oauth/callback

# 若 API 只有 HTTP 公网 IP、无 HTTPS 域名，可用 Cloudflare Quick Tunnel（在 API 所在机器上）：
#   brew install cloudflared   # 首次
#   npm run tunnel:start       # 得到 https://xxx.trycloudflare.com（每次重启会变）
# 将隧道地址填入 OAuth 重定向 URI 与下方 PUBLIC_BASE_URL / GOOGLE_OAUTH_REDIRECT_URI
# 隧道 URL 保存在 data/cloudflared.url；日志 data/cloudflared.log

# ── 固定子域名（推荐，与 NAS 可共用同一 Cloudflare 域名）────────────────
# 例：NAS 用 nas.example.com，API 用 api.example.com
# CLOUDFLARE_TUNNEL_HOSTNAME=api.example.com
# CLOUDFLARE_TUNNEL_NAME=file-service-api
# TUNNEL_TARGET=http://127.0.0.1:3000
# 或在 Zero Trust 控制台创建隧道后填 Token（见 config/cloudflared/README.md）：
# CLOUDFLARE_TUNNEL_TOKEN=
# 命令：npm run tunnel:login → npm run tunnel:setup → npm run tunnel:run → npm run tunnel:sync-env

# 列表分享邮件（未配置时「分享列表」不可用）
# WEB_APP_URL=http://localhost:5173
# SHARE_LINK_TTL_SECONDS=604800
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="敬拜诗库 <noreply@yourchurch.org>"

# 列表分享邮件 / OAuth 回跳（本机前端 + Vercel 双域名时逗号分隔 CORS）
# CORS_ORIGIN=https://frontend.youtvs.com,https://your-app.vercel.app
# WEB_APP_URL=https://frontend.youtvs.com
# VIP 用户专属播放列表（播放列表 UUID，管理员在后台创建后填入）
# VIP_PLAYLIST_ID=

# Web 前端（Vercel 构建时 BACKEND_URL 指向 API；开发可留空走 Next 代理）
# BACKEND_URL=https://api.example.com

# App Store 审核演示账号（npm run seed:app-store-review）
# APP_STORE_REVIEW_EMAIL=appstore.review@playlistplayer.app
# APP_STORE_REVIEW_PASSWORD=ReviewDemo2026!
# APP_STORE_REVIEW_FIRST_NAME=App Store
# APP_STORE_REVIEW_LAST_NAME=Reviewer
# APP_STORE_REVIEW_PLAYLIST_URL=https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID
# VITE_API_KEY=与 API_KEY 相同（启用鉴权时）

# 客户端识别（请求头 X-Client）
# Web: file-service-web
# 手机 App: playlist-player 或 worship-player（旧版）
# 未带 X-Client 的请求按 Web 处理
