DATABASE_URL=postgresql://fileservice:fileservice@localhost:5432/fileservice
STORAGE_BACKEND=fs
LOCAL_STORAGE_DIR=./data/storage

# API only
PORT=3000
# 前端地址（CORS + 分享邮件链接，逗号分隔多个）
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# WEB_APP_URL=http://localhost:5173
MAX_UPLOAD_MB=200
# 可选：设置后所有 /v1/* 请求需携带 Authorization: Bearer <key> 或 X-API-Key
# API_KEY=your-secret-api-key-min-8-chars
# 用户认证（默认开启，所有 /v1/* 需登录；设为 false 可本地开放）
# AUTH_REQUIRED=true
# USER_SESSION_TTL_SECONDS=1892160000
# 注册用户默认为 member；管理员在后台 /admin 调整角色
# （以下两项已不再用于注册自动赋权，可忽略）
# ADMIN_EMAILS=
# WORSHIP_TEAM_EMAILS=
DOWNLOAD_HMAC_SECRET=replace-with-at-least-16-chars
DOWNLOAD_URL_TTL_SECONDS=3600
PUBLIC_BASE_URL=http://localhost:3000

# 可选：API 托管前端静态资源（一般不需要，前后端已分离）
# STATIC_DIR=./frontend/dist

# 开发：Vite 代理目标（默认 http://localhost:3000）
# VITE_DEV_API_PROXY=http://localhost:3000

# Worker only（本机开发）
SOFFICE_PATH=soffice
# MP3 缓存：需安装 yt-dlp + ffmpeg（brew install yt-dlp ffmpeg）并运行 worker
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
# YOUTUBE_AUDIO_WORKER_CONCURRENCY=1
# 并行处理的合并任务数（默认 1；LibreOffice 占用内存大，勿设过高）
WORKER_CONCURRENCY=1

# 可选：设置 RUN_MIGRATIONS=0 可禁用 API 启动时自动迁移
# RUN_MIGRATIONS=1
# 生产环境默认关闭 Swagger；开发自动开启，或设 ENABLE_OPENAPI=1 强制开启
# ENABLE_OPENAPI=1
# 全局限流（Redis 计数，按 API Key 或 IP）
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# 上传接口更严格限流（同一窗口内 POST 上传次数）
RATE_LIMIT_UPLOAD_MAX=30

# 可选：Webhook 签名密钥（Worker POST 时设置 X-Webhook-Signature HMAC-SHA256）
# WEBHOOK_SECRET=your-webhook-signing-secret

# 可选：YouTube Data API v3 密钥（未配置时也会尝试自动读取链接；配置后更稳定）
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# YOUTUBE_API_KEY=your-youtube-data-api-key

# 列表分享邮件（未配置时「分享列表」不可用）
# WEB_APP_URL=http://localhost:5173
# SHARE_LINK_TTL_SECONDS=604800
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="敬拜诗库 <noreply@yourchurch.org>"

# Web 前端（构建时注入；生产分离部署必填，开发可留空走 Vite 代理）
# VITE_API_URL=http://localhost:3000
# VITE_API_KEY=与 API_KEY 相同（启用鉴权时）
