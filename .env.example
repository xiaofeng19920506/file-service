# 生产环境可设为站点根 URL（含 https）
# NEXT_PUBLIC_SITE_URL=https://files.example.com

DATABASE_URL=postgresql://fileservice:fileservice@localhost:5432/fileservice
FILE_STORAGE_DIR=./data/files
CHUNK_STORAGE_DIR=./data/chunks
# 单文件与分片合并后的总大小上限（字节），默认 500MB
MAX_UPLOAD_BYTES=524288000

# 建表：docker compose up -d 后在本机终端执行 npm run db:push。
# 若与旧库结构冲突且可清空数据：docker compose down -v && docker compose up -d && npm run db:push:force
